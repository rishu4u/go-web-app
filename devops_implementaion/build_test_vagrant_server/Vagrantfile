# ============================================================
# Vagrant Server: Build & Test
# Purpose : Spin up an Ubuntu 22.04 VM, install Go 1.22,
#            and run `go test ./...` against the go-web-app source.
# Usage   : vagrant up
# ============================================================
Vagrant.configure("2") do |config|

  config.vm.box = "generic/ubuntu2204"

  # Port-forward so you can hit the app on http://localhost:8080
  config.vm.network "forwarded_port", guest: 8080, host: 8080

  # Give the VM a private network IP for easy SSH access
  config.vm.network "private_network", ip: "192.168.56.10"

  config.vm.provider "libvirt" do |lv|
    lv.memory = 2048
    lv.cpus   = 2
  end

  # Sync the application source into the VM
  # The path is relative to THIS Vagrantfile
  config.vm.synced_folder "../../go-web-app", "/home/vagrant/go-web-app",
    owner: "vagrant", group: "vagrant"

  # Run the provision script as root
  config.vm.provision "shell", path: "provision_test.sh"

end
